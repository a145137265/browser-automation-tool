{
  "name": "browser-automation-suite",
  "version": "1.0.0",
  "description": "专业浏览器自动化控制工具 - 基于 Playwright + Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "browser-suite": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "api": "ts-node src/api/server.ts",
    "clean": "rm -rf dist logs screenshots recordings",
    "test": "jest"
  },
  "keywords": ["playwright", "browser", "automation", "puppeteer", "headless"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.40.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "node-forge": "^1.3.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  }
}
